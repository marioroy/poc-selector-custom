+		atomic64_set(&sd->shared->poc_idle_cpus_mask, 0);
+
+		/* Build LLC member bitmasks for reader-side aggregation */
+		{
+			u64 members = 0, pmembers = 0;
+			int cpu_iter;
+
+			for_each_cpu(cpu_iter, sd_span) {
+				int core = cpumask_first(cpu_smt_mask(cpu_iter));
+				int bit = cpu_iter - sd_id;
+
+				if ((unsigned int)bit < 64)
+					members |= 1ULL << bit;
+
+				bit = core - sd_id;
+				if ((unsigned int)bit < 64)
+					pmembers |= 1ULL << bit;
+			}
