
Piece-Of-Cake (POC) awareness patch for sched_ext.

 - Disable POC when switching to sched_ext
 - Restore POC when switching back

Signed-off-by: Mario Roy <>
---
 kernel/sched/ext.c | 23 +
 1 file changed, 23 insertions(+), 0 deletions(-)

diff -uarp a/kernel/sched/ext.c b/kernel/sched/ext.c
--- a/kernel/sched/ext.c
+++ b/kernel/sched/ext.c
@@ -9,6 +9,12 @@
 #include <linux/btf_ids.h>
 #include "ext_idle.h"
 
+#ifdef CONFIG_SCHED_POC_SELECTOR
+DEFINE_STATIC_KEY_FALSE(sched_poc_transfer_state);
+extern struct static_key_true sched_poc_enabled;
+extern void poc_resync_idle_state(void);
+#endif /* CONFIG_SCHED_POC_SELECTOR */
+
 /*
  * NOTE: sched_ext is in the process of growing multiple scheduler support and
  * scx_root usage is in a transitional state. Naked dereferences are safe if the
@@ -4170,6 +4176,15 @@ static void scx_disable_workfn(struct kthread_work *work)
 	 */
 	cpus_read_lock();
 	RCU_INIT_POINTER(scx_root, NULL);
+#ifdef CONFIG_SCHED_POC_SELECTOR
+	/* Restore POC when switching back to sched_fair */
+	if (static_branch_likely(&sched_poc_transfer_state)) {
+		static_branch_disable_cpuslocked(&sched_poc_transfer_state);
+		static_branch_enable_cpuslocked(&sched_poc_enabled);
+		/* resync_idle expects caller to hold cpus_read_lock() */
+		poc_resync_idle_state();
+	}
+#endif /* CONFIG_SCHED_POC_SELECTOR */
 	cpus_read_unlock();
 
 	/*
@@ -4926,6 +4941,14 @@ static void scx_enable_workfn(struct kthread_work *work)
 	scx_cgroup_unlock();
 	percpu_up_write(&scx_fork_rwsem);
 
+#ifdef CONFIG_SCHED_POC_SELECTOR
+	/* Disable Piece-Of-Cake (POC) when switching to sched_ext */
+	if (static_branch_likely(&sched_poc_enabled)) {
+		static_branch_disable_cpuslocked(&sched_poc_enabled);
+		static_branch_enable_cpuslocked(&sched_poc_transfer_state);
+	}
+#endif /* CONFIG_SCHED_POC_SELECTOR */
+
 	/*
 	 * All tasks are READY. It's safe to turn on scx_enabled() and switch
 	 * all eligible tasks.
-- 
